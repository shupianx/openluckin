            "type": "string"
          },
          "type": "array"
        },
        "deptId": {
          "description": "门店id",
          "type": "integer"
        },
        "latitude": {
          "description": "纬度",
          "type": "number"
        },
        "longitude": {
          "description": "经度",
          "type": "number"
        },
        "productList": {
          "description": "订单商品列表",
