              },
              "skuCode": {
                "type": "string"
              }
            },
            "required": [
              "amount",
              "productId",
              "skuCode"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "deptId",
        "productList",
        "longitude",
        "latitude"
      ],
      "returnDirect": false,
      "type": "object"
    }
