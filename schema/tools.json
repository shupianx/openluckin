    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "deptName": {
          "description": "门店名称",
          "type": "string"
        },
        "latitude": {
          "description": "纬度",
          "type": "number"
        },
        "longitude": {
          "description": "经度",
          "type": "number"
        }
      },
      "required": [
        "longitude",
        "latitude"
      ],
      "returnDirect": false,
      "type": "object"
    }
  },
  {
    "name": "searchProductForMcp",
    "description": "瑞幸咖啡根据用户传入query， 匹配商品推荐结果",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "deptId": {
          "description": "门店ID",
          "type": "integer"
        },
        "query": {
          "description": "用户原始查询文本",
          "type": "string"
        }
      },
      "required": [
        "deptId",
        "query"
      ],
      "returnDirect": false,
      "type": "object"
    }
  },
  {
    "name": "switchProduct",
    "description": "瑞幸咖啡商品属性切换",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "amount": {
          "description": "商品数量",
          "type": "integer"
        },
        "attrOperationParam": {
          "description": "商品属性切换参数",
          "properties": {
            "attributeId": {
              "format": "int64",
              "type": "integer"
            },
            "subAttr": {
              "properties": {
                "attributeId": {
                  "format": "int64",
                  "type": "integer"
                },
                "operation": {
                  "format": "int32",
                  "type": "integer"
                }
              },
              "required": [
                "attributeId",
                "operation"
              ],
              "type": "object"
            }
          },
          "required": [
            "attributeId",
            "subAttr"
          ],
          "type": "object"
        },
        "deptId": {
          "description": "门店ID",
          "type": "integer"
        },
        "productId": {
          "description": "商品ID",
          "type": "integer"
        },
        "skuCode": {
          "description": "商品SKU编码",
          "type": "string"
        }
      },
      "required": [
        "deptId",
        "productId",
        "skuCode",
        "attrOperationParam",
        "amount"
      ],
      "returnDirect": false,
      "type": "object"
    }
  },
  {
    "name": "queryProductDetailInfo",
